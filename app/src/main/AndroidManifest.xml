<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Android 13+ scoped media access -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Pre-Android 13 fallback -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Foreground progress notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Foreground service so large backfills survive the app being backgrounded.
         dataSync type: we are processing on-device user content, not networking. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Network use: the one-time CLIP model download, and the optional, off-by-default,
         user-initiated QR link-preview resolution. All inference is local. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Read connectivity so QR resolution can honor the Wi-Fi-only preference. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- In-app camera capture for the real-world inventory feature. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <!-- Pre-Android 10 (no scoped storage): writing a capture into shared MediaStore
         needs this. On API 29+ MediaStore insert needs no storage write permission. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:name=".ScreenshotClassifierApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ScreenshotClassifier">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ScreenshotClassifier">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Hilt provides the WorkManager factory; disable default initializer -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Declare the foreground-service type on WorkManager's service so the
             processing worker can run as a dataSync foreground service. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

    </application>

</manifest>
