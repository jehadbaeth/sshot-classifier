<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme. Visuals are driven by Compose MaterialTheme; this only needs
         to provide a no-action-bar window for the host activity. -->
    <style name="Theme.ScreenshotClassifier" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
